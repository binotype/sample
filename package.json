{
	"name": "@binotype/sample",
	"version": "0.0.1",
	"license": "MIT",
	"description": "A sample project for Binotype components",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/binotype/sample.git"
	},
	"bugs": {
		"url": "https://github.com/binotype/sample/issues"
	},
	"homepage": "https://github.com/binotype/sample/tree/master-1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "stencil build --prerender",
		"start": "stencil build --dev --watch --serve",
		"test": "vitest --run --allowOnly",
		"coverage": "vitest --coverage",
		"generate": "stencil generate",
		"lint": "eslint 'src/**/*.{js,ts,tsx}'",
		"fix": "eslint 'src/**/*.{js,ts,tsx}' --fix",
		"clean": "rm -rf .stencil/ dist/ node_modules/ loader/ www/",
		"test:browser": "vitest --config=vitest.browser.config.ts"
	},
	"dependencies": {
		"isly": "^1.4.0",
		"isoly": "^3.1.3"
	},
	"devDependencies": {
		"@stencil/core": "^4.38.2",
		"@stencil/sass": "^3.2.3",
		"@types/node": "^24.10.0",
		"@types/pvutils": "^1.0.4",
		"@typescript-eslint/eslint-plugin": "^8.46.3",
		"@typescript-eslint/parser": "^8.46.3",
		"@vitest/browser": "^4.0.6",
		"@vitest/browser-webdriverio": "^4.0.6",
		"@vitest/coverage-istanbul": "^4.0.6",
		"eslint": "^8.56.0",
		"eslint-plugin-prettierx": "github:utily/eslint-plugin-prettierx#utily-20231004",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"happy-dom": "^20.0.10",
		"jsdom": "^27.1.0",
		"prettierx": "github:utily/prettierx#utily-20231004",
		"puppeteer": "^24.28.0",
		"stencil-router-v2": "^0.6.0",
		"typescript": "5.9.3",
		"unplugin-stencil": "^0.4.0",
		"vite": "^7.1.12",
		"vitest": "^4.0.6",
		"web-file-polyfill": "^1.0.4",
		"webdriverio": "^9.20.0"
	}
}
