{
	"name": "@binotype/sample",
	"private": true,
	"version": "0.0.1",
	"license": "MIT",
	"description": "Binotype Sample Website",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/binotype/sample.git"
	},
	"bugs": {
		"url": "https://github.com/binotype/sample/issues"
	},
	"homepage": "https://github.com/binotype/sample/tree/master-1.0",
	"type": "module",
	"scripts": {
		"build": "stencil build --prerender",
		"start": "stencil build --dev --watch --serve --prerender",
		"test": "stencil test --spec --e2e",
		"test.watch": "stencil test --spec --e2e --watchAll",
		"generate": "stencil generate",
		"lint": "eslint 'src/**/*.{js,ts,tsx}'",
		"fix": "eslint 'src/**/*.{js,ts,tsx}' --fix",
		"clean": "rm -rf .stencil/ dist/ node_modules/ loader/ www/",
		"verify": "npm run lint && npm run test && npm run build"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.4",
		"@eslint/js": "^10.0.1",
		"@stencil/core": "4.43.2",
		"@stencil/sass": "3.2.3",
		"@types/jest": "^30.0.0",
		"@types/node": "25.3.2",
		"@types/showdown": "^2.0.6",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"eslint": "^10.0.2",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"jest": "^30.2.0",
		"prettier": "^3.8.1",
		"puppeteer": "^24.37.5",
		"sass": "1.97.3",
		"stencil-inline-svg": "1.1.0",
		"stencil-router-v2": "^0.6.0",
		"typescript": "5.9.3",
		"unplugin-stencil": "^0.4.1"
	},
	"dependencies": {
		"@binotype/site": "^0.21.0",
		"isly": "^1.8.0",
		"showdown": "^2.1.0",
		"smoothly": "^1.108.0",
		"tidily": "^0.2.7"
	}
}
